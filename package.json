{
  "name": "rig-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based 2D SVG rigging and animation editor that exports Jetpack Compose rig code",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --project unit",
    "test:interaction": "vitest run --project interaction",
    "pages": "vite build --outDir docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0"
  },
  "devDependencies": {
    "@rive-app/canvas": "^2.38.5",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
