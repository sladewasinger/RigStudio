{
  "name": "rig-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-based 2D SVG rigging and animation editor that exports Jetpack Compose rig code",
  "bin": {
    "rig-studio": "src/headless/bin.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run --project unit",
    "test:interaction": "vitest run --project interaction",
    "export:take-pill": "vitest run --config scripts/exportPipTakePill.config.ts",
    "rig": "tsx src/headless/cli.ts",
    "pages": "vite build --outDir dist --base=/RigStudio/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@resvg/resvg-js": "^2.6.2",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@rive-app/canvas": "^2.38.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
